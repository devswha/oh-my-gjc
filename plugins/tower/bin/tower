#!/usr/bin/env python3
"""tower — control-tower CLI: operator decision queue + glance/notify passthrough.

  tower queue                 list pending decisions
  tower queue all             list pending + done
  tower queue add <src> <txt> enqueue a decision (idempotent per source+text)
  tower queue done <id>       mark resolved
  tower queue undo <id>       reopen
  tower queue rm <id>         delete
  tower list                  matching sessions            (→ tower-notify.sh --list)
  tower peek [N]              glance last N lines/session  (→ tower-notify.sh --peek)
  tower models                running model per session    (→ tower-notify.sh --models)
  tower notify <session|--all> <msg>   inject (TUI-trap defended) (→ tower-notify.sh)
  tower watch [args...]       run the busy→idle watcher     (→ session_watch.py)

Queue storage: $TOWER_QUEUE_FILE > $TOWER_HOME/queue.json > ~/.gjc/tower/queue.json.
"""
from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path

BIN = Path(__file__).resolve().parent
sys.path.insert(0, str(BIN))
import queue_store as qs  # noqa: E402


def _print_items(items: list[dict]) -> None:
    if not items:
        print("(empty)")
        return
    for i in items:
        mark = "✓" if i.get("done") else "●"
        print(f"  {i.get('id')} {mark} [{i.get('source')}] {i.get('text')}  {i.get('ts', '')}")


def cmd_queue(argv: list[str]) -> int:
    sub = argv[0] if argv else "list"
    if sub in ("list", "all"):
        data = qs.load()
        pending, total = qs.counts(data)
        print(f"decision queue  {pending} pending / {total} total")
        _print_items(qs.view(data, include_done=(sub == "all")))
        return 0
    if sub == "add":
        if len(argv) < 3:
            print("usage: tower queue add <source> <text>", file=sys.stderr)
            return 2
        source, text = argv[1], " ".join(argv[2:])
        data = qs.load()
        item = qs.add_item(data, source, text)
        if item is None:
            print("skip: empty text", file=sys.stderr)
            return 2
        qs.save(data)
        pending, total = qs.counts(data)
        print(f"decision queue  {pending} pending / {total} total")
        _print_items(qs.view(data))
        return 0
    if sub in ("done", "undo", "rm"):
        if len(argv) < 2 or not argv[1].isdigit():
            print(f"usage: tower queue {sub} <id>", file=sys.stderr)
            return 2
        item_id = int(argv[1])
        data = qs.load()
        if sub == "rm":
            ok = qs.remove_item(data, item_id)
        else:
            ok = qs.set_done(data, item_id, sub == "done")
        if not ok:
            print(f"no such item: {item_id}", file=sys.stderr)
            return 1
        qs.save(data)
        _print_items(qs.view(data, include_done=True))
        return 0
    print(f"unknown queue subcommand: {sub}", file=sys.stderr)
    return 2


def passthrough(script: str, args: list[str]) -> int:
    path = str(BIN / script)
    try:
        return subprocess.run([path, *args] if script.endswith(".sh") else ["python3", path, *args]).returncode
    except OSError as exc:
        print(f"tower: cannot run {script}: {exc}", file=sys.stderr)
        return 1


def main() -> int:
    if len(sys.argv) < 2:
        print(__doc__)
        return 2
    cmd, argv = sys.argv[1], sys.argv[2:]
    if cmd == "queue":
        return cmd_queue(argv)
    if cmd == "list":
        return passthrough("tower-notify.sh", ["--list"])
    if cmd == "peek":
        return passthrough("tower-notify.sh", ["--peek", *argv])
    if cmd == "models":
        return passthrough("tower-notify.sh", ["--models"])
    if cmd == "notify":
        return passthrough("tower-notify.sh", argv)
    if cmd == "watch":
        return passthrough("session_watch.py", argv)
    print(__doc__)
    return 2


if __name__ == "__main__":
    sys.exit(main())
