# gjc runtime state (never commit local session/plugin state)
.gjc/

# OS / editor noise
.DS_Store
*.swp
*~

# Dependencies (only if a plugin uses them)
node_modules/

# Secrets — NEVER commit real API keys
.env
.env.*
!.env.example

# Local server logs
*.log

# insane-review engine runtime output + python cache
.insane-review/
__pycache__/
*.pyc

# OMO/LazyCodex worker runtime state (created by lazycodex-gjc dogfooding)
.omo/
