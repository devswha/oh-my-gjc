# =============================================================================
#  Gajae Code (gjc) — 환경 템플릿.  `.env`로 복사해 키만 채워라.
# -----------------------------------------------------------------------------
#  ⚠️  이 파일(.env.example)은 플레이스홀더 템플릿이라 커밋된다.
#      실키가 든 너의 `.env`는 .gitignore 대상이며 절대 커밋하지 마라.
#
#  gjc 키 로딩 방식(중요): gjc는 보안상 프로젝트 cwd의 `.env`를 자격증명으로는
#  "의도적으로 무시"한다. 키는 신뢰 위치에서 읽혀야 한다. 이 레포의 .env를
#  gjc 홈으로 심링크해 두면 gjc가 자동으로 읽는다(레포 루트에서 1회 실행):
#       ln -sf "$(pwd)/.env" ~/.gjc/.env
#  source도, 셸 재시작도 불필요.
#  자격증명 우선순위: 라이브 env → ~/.gjc/agent/.env → ~/.gjc/.env → ~/.env
#  (프로젝트 cwd/.env는 자격증명으로 무시됨)
#
#  모델: Claude / OpenAI Codex / Kimi는 OAuth 로그인으로 동작(API 키 불필요).
#       gjc --mpreset claude-max   # 최고 품질
#       gjc --mpreset kimi         # 저비용 일꾼/병렬
#  웹 검색:  gjc config set providers.webSearch exa     # 폴백: duckduckgo
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
#  1순위 · 검색 (가장 큰 성능 구멍 — 여기부터 채워라)
# ─────────────────────────────────────────────────────────────────────────────

# Exa — 코드/문서/시맨틱 검색 품질 최고. 무료 1,000/월, 이후 표준 $7/1k.
#   발급: https://exa.ai  (Dashboard → API Keys)
#   기본 검색을 Exa로:  gjc config set providers.webSearch exa
EXA_API_KEY=

# Tavily — LLM 에이전트 전용. 무료 1,000 크레딧/월(카드 불필요). 폴백/대체용.
#   발급: https://tavily.com
TAVILY_API_KEY=

# Perplexity — 합성 답변/최신성.
#   (A) API 키:  https://www.perplexity.ai/settings/api   (Sonar, 요청당 과금)
PERPLEXITY_API_KEY=
#   (B) 또는 Perplexity Pro 구독이 있으면 세션 쿠키로 키리스 사용:
#       브라우저 perplexity.ai 로그인 → 쿠키 문자열 붙여넣기
PERPLEXITY_COOKIES=

# Brave — 범용. 무료 티어 축소 추세($5/1k). 우선순위 낮음.
BRAVE_API_KEY=

# Kagi — 고품질·프리미엄($15~25/1k). 보통 과함.
KAGI_API_KEY=

# Jina — 보조 검색/리더.
JINA_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
#  2순위 · 모델 프로바이더 (선택 — Claude/Codex는 OAuth로 동작, 키 불필요)
# ─────────────────────────────────────────────────────────────────────────────

# Gemini — 품질 점프는 아니고 싼 유틸. 1M 컨텍스트 + 초저가 flash(smol 역할).
#   무료 티어 있음.  발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 아래는 보통 불필요(구독 OAuth로 커버). 직접 API 과금할 때만 채워라.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
ZAI_API_KEY=
MINIMAX_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
#  키 채운 뒤 (source 불필요 — 심링크로 gjc가 자동으로 읽음)
# ─────────────────────────────────────────────────────────────────────────────
#  검색 프로바이더 설정:
#     gjc config set providers.webSearch exa
#  검증:
#     gjc web-search "test query" --limit 2 --compact     # Provider: Exa 확인
#  심층 조사 모드(비용↑):
#     gjc config set exa.enableResearcher true
